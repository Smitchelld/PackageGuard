<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#F8F9FA">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="16dp">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Pełna Konfiguracja Paczki"
            android:textSize="22sp"
            android:textStyle="bold"
            android:textColor="#0D6EFD"
            android:layout_marginBottom="16dp"/>

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="AKTYWNE ALARMY"
            android:textStyle="bold"
            android:textSize="12sp"
            android:textColor="#666"/>

        <GridLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:columnCount="2"
            android:layout_marginBottom="16dp">
            <Switch android:id="@+id/swShockEn" android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Wstrząsy" />
            <Switch android:id="@+id/swTempEn" android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Temperatura" />
            <Switch android:id="@+id/swHumEn" android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Wilgotność" />
            <Switch android:id="@+id/swPresEn" android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Ciśnienie" />
            <Switch android:id="@+id/swLightEn" android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Światło" />
            <Switch android:id="@+id/swBatEn" android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Bateria" />
        </GridLayout>

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="REAKCJE URZĄDZENIA"
            android:textStyle="bold"
            android:textSize="12sp"
            android:textColor="#666"/>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:layout_marginBottom="16dp">
            <Switch android:id="@+id/swBuzzEn" android:layout_width="match_parent" android:layout_height="wrap_content" android:text="Buzzer (Dźwięk)"/>
            <Switch android:id="@+id/swMotEn" android:layout_width="match_parent" android:layout_height="wrap_content" android:text="Silnik (Wibracje)"/>
            <Switch android:id="@+id/swLedEn" android:layout_width="match_parent" android:layout_height="wrap_content" android:text="Dioda LED RGB"/>
            <Switch android:id="@+id/swStealth" android:layout_width="match_parent" android:layout_height="wrap_content" android:text="TRYB CICHY" android:textColor="#D32F2F" android:textStyle="bold"/>
        </LinearLayout>

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="PROGI I WARTOŚCI"
            android:textStyle="bold"
            android:textSize="12sp"
            android:textColor="#666"/>

        <EditText android:id="@+id/etShockG" android:layout_width="match_parent" android:layout_height="wrap_content" android:hint="Czułość wstrząsu (G)" android:inputType="numberDecimal"/>

        <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:orientation="horizontal">
            <EditText android:id="@+id/etTempMin" android:layout_width="0dp" android:layout_weight="1" android:layout_height="wrap_content" android:hint="Temp Min" android:inputType="numberDecimal"/>
            <EditText android:id="@+id/etTempMax" android:layout_width="0dp" android:layout_weight="1" android:layout_height="wrap_content" android:hint="Temp Max" android:inputType="numberDecimal"/>
        </LinearLayout>

        <EditText android:id="@+id/etBatMin" android:layout_width="match_parent" android:layout_height="wrap_content" android:hint="Min. Napięcie Baterii (V)" android:inputType="numberDecimal"/>
        <EditText android:id="@+id/etInterval" android:layout_width="match_parent" android:layout_height="wrap_content" android:hint="Interwał raportu (sekundy)" android:inputType="number"/>
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Wiecej możliwości dostępne przez dashboard na stronie"
            android:textStyle="bold"
            android:textSize="12sp"
            android:textColor="#666"/>
        <Button
            android:id="@+id/btnSaveSettings"
            android:layout_width="match_parent"
            android:layout_height="60dp"
            android:text="ZAPISZ I WYŚLIJ"
            android:layout_marginTop="24dp"
            android:backgroundTint="#0D6EFD"
            android:textColor="#FFFFFF"/>

    </LinearLayout>
</ScrollView>